NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=b2762925420@163.com
AI_SERVICE_URL=http://127.0.0.1:8000
APP_RUNTIME_MODE=preview
NEXT_PUBLIC_APP_RUNTIME_MODE=preview
YOUTUBE_API_KEY=
YOUTUBE_FETCH_MODE=auto
YOUTUBE_REQUEST_TIMEOUT_MS=12000
ENABLE_E2E_AUTH_BYPASS=false

# Data backend: mock | supabase | auto
DATA_BACKEND=supabase

# Supabase Auth + DB (RLS user-session writes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-side aliases (if NEXT_PUBLIC_* is not set)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: use pre-created Stripe recurring prices instead of inline recurring price_data
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# Optional: defaults to cny
STRIPE_CURRENCY=cny

# Optional: custom CJK fonts for PDF export. On Windows dev, the app also auto-detects common fonts.
PDF_CJK_FONT_PATH=
PDF_CJK_BOLD_FONT_PATH=
