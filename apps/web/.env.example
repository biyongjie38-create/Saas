NEXT_PUBLIC_APP_URL=
AI_SERVICE_URL=http://127.0.0.1:8000
YOUTUBE_API_KEY=
YOUTUBE_FETCH_MODE=auto

# Data backend: mock | supabase | auto
DATA_BACKEND=supabase

# Supabase Auth + DB (RLS user-session writes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-side aliases (if NEXT_PUBLIC_* is not set)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: use pre-created Stripe recurring prices instead of inline recurring price_data
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# Optional: defaults to cny
STRIPE_CURRENCY=cny
